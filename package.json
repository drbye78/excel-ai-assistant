{
  "name": "excel-ai-assistant",
  "version": "1.0.0",
  "description": "AI-powered assistant for Excel with full workbook element support",
  "main": "index.js",
  "scripts": {
    "prebuild": "node scripts/build-manifest.js --production",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack-dev-server --mode development",
    "start": "npm run dev-server",
    "start:server": "node server/index.js",
    "dev": "concurrently \"npm run dev-server\" \"npm run start:server\"",
    "lint": "eslint src/**/*.ts",
    "validate": "office-addin-manifest validate manifest.xml",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "@fluentui/react": "^8.112.0",
    "@microsoft/office-js": "^1.1.83",
    "@microsoft/office-js-helpers": "^1.0.2",
    "axios": "^1.6.0",
    "core-js": "^3.33.0",
    "express": "^4.18.2",
    "openai": "^4.20.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "regenerator-runtime": "^0.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.23.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/office-js": "^1.0.363",
    "@types/office-runtime": "^1.0.35",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.0",
    "dotenv": "^16.3.0",
    "eslint": "^8.52.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-loader": "^4.2.0",
    "html-webpack-plugin": "^5.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-watch-typeahead": "^2.2.2",
    "office-addin-cli": "^1.0.50",
    "office-addin-debugging": "^5.0.13",
    "office-addin-dev-certs": "^1.11.3",
    "office-addin-manifest": "^1.12.11",
    "os-browserify": "^0.3.0",
    "process": "^0.11.10",
    "style-loader": "^3.3.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "browserslist": [
    "last 2 versions",
    "not ie 11"
  ],
  "keywords": [
    "excel",
    "add-in",
    "ai",
    "assistant",
    "openai",
    "copilot",
    "office-js"
  ],
  "author": "AI Assistant Team",
  "license": "MIT",
