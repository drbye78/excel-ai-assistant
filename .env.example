# Excel AI Assistant - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# AI PROVIDER CONFIGURATION
# =============================================================================

# --- Option 1: OpenAI (Recommended for beginners) ---
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# --- Option 2: Azure OpenAI Service ---
# OPENAI_API_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment-name
# OPENAI_API_KEY=your-azure-api-key
# OPENAI_MODEL=gpt-4
# AZURE_OPENAI_API_VERSION=2024-02-01

# --- Option 3: Local AI (LM Studio) ---
# OPENAI_API_URL=http://localhost:1234/v1
# OPENAI_API_KEY=not-needed-for-local
# OPENAI_MODEL=local-model

# --- Option 4: Local AI (Ollama) ---
# OPENAI_API_URL=http://localhost:11434/v1
# OPENAI_API_KEY=not-needed-for-ollama
# OPENAI_MODEL=llama2

# --- Option 5: Anthropic Claude (via compatible proxy) ---
# OPENAI_API_URL=https://your-claude-proxy.com/v1
# OPENAI_API_KEY=your-claude-api-key
# OPENAI_MODEL=claude-3-opus-20240229

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Port for the local Express server (if using backend features)
PORT=3001

# Enable/disable server-side features
ENABLE_SERVER=false

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Development, production, or test
NODE_ENV=development

# Default language: en-US or ru-RU
DEFAULT_LOCALE=en-US

# Enable/disable telemetry (anonymous usage statistics)
ENABLE_TELEMETRY=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable advanced analytics features
ENABLE_ADVANCED_ANALYTICS=true

# Enable Power Query/DAX features
ENABLE_POWER_FEATURES=true

# Enable recipe sharing
ENABLE_RECIPE_SHARING=false

# Enable enterprise authentication
ENABLE_ENTERPRISE_AUTH=false

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Maximum rows to process in batch operations
MAX_BATCH_ROWS=10000

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# Enable performance mode (faster, less detailed)
PERFORMANCE_MODE=false

# =============================================================================
# DEBUG SETTINGS
# =============================================================================

# Enable debug logging
DEBUG=false

# Log level: error, warn, info, debug, verbose
LOG_LEVEL=info

# Enable React strict mode
REACT_STRICT_MODE=true

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Allowed CORS origins (comma-separated)
# CORS_ORIGINS=https://localhost:3000,https://your-domain.com

# Session secret (if using server-side sessions)
# SESSION_SECRET=your-secret-key-here

# =============================================================================
# BUILD SETTINGS
# =============================================================================

# Production URL for manifest
# PRODUCTION_URL=https://your-production-domain.com

# Build output directory
BUILD_DIR=dist
